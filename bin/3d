#!/usr/bin/env python3
# =============================================================================
# 3d — a scriptable CLI for AI-assisted, reference-photo-driven parametric 3D
#      modeling in OpenSCAD. Thin Python dispatcher: it resolves the repo root
#      through this (possibly symlinked) launcher, puts lib/ on sys.path, and
#      hands off to cli.dispatch.main, which discovers commands from the
#      lib/commands/ registry. Adding a command = drop a module in lib/commands/;
#      no edit here. See lib/cli/registry.py for the command-authoring contract.
# =============================================================================
from __future__ import annotations

import os
import sys

# Resolve the repo root THROUGH the bin/3d symlink (e.g. ~/.local/bin/3d -> this file).
_self = os.path.realpath(__file__)
_repo = os.path.dirname(os.path.dirname(_self))
os.environ.setdefault("REPO_ROOT", _repo)
sys.path.insert(0, os.path.join(_repo, "lib"))

from cli.dispatch import main  # noqa: E402  (after sys.path setup)

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
