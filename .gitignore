# python
.venv/
__pycache__/
*.pyc

# OpenSCAD libraries are cloned on demand (first-run bootstrap), not vendored.
libs/*/

# test / scratch render outputs
*.png
*.stl
*.3mf
*.csg
match_work/
score/

# keep example sources and any intentionally-committed reference images
!examples/*.scad
!docs/img/*.png
!docs/img/*.svg

# local tooling state
.serena/
.claude/*
# but keep the committed, shared harness settings (auto-mode)
!.claude/settings.json
# personal per-machine Claude settings stay local (gitignored)
.claude/settings.local.json

# CI / coverage
.coverage

# local project config (not committed)
/3d.yaml
