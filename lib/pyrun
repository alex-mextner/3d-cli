#!/usr/bin/env bash
# lib/pyrun — run a python tool with its deps, degrading gracefully.
#
# Strategy (first that works):
#   1. $REPO_ROOT/.venv/bin/python   — if the user bootstrapped a venv.
#   2. uv run --with <deps> python3  — uv resolves deps on the fly (no global installs).
#   3. system python3                — only if deps already importable; else a clear error.
#
# Usage:  pyrun "<comma-sep deps>" <script.py> [args...]
#   e.g.  pyrun "trimesh,manifold3d,numpy" lib/mesh_check.py part.stl
#
# Env:  PY3D_NO_UV=1  forces skipping uv (use venv or system python only).

set -uo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"; SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
: "${REPO_ROOT:=$(cd -P "$(dirname "$SOURCE")/.." && pwd)}"

# DEPS may be EMPTY (caller wants no extra deps — e.g. render's optional mesh stack);
# require it to be SET (?) but allow empty (no :), else uv adds no --with flags.
DEPS="${1?usage: pyrun '<deps>' script.py [args]}"; shift
VENV_PY="$REPO_ROOT/.venv/bin/python"

if [ -x "$VENV_PY" ]; then
    exec "$VENV_PY" "$@"
fi

if [ -z "${PY3D_NO_UV:-}" ] && command -v uv >/dev/null 2>&1; then
    # build --with flags from the comma list. DEPS may be EMPTY (no extra deps) — guard
    # every empty-array expansion under `set -u` (bash 3/4 treats "${arr[@]}" on an empty
    # array as unbound).
    args=()
    if [ -n "$DEPS" ]; then
        IFS=',' read -r -a deplist <<< "$DEPS"
        for d in ${deplist[@]+"${deplist[@]}"}; do [ -n "$d" ] && args+=( "--with" "$d" ); done
    fi
    exec uv run ${args[@]+"${args[@]}"} python3 "$@"
fi

if command -v python3 >/dev/null 2>&1; then
    # last resort: deps must already be importable; the script reports its own
    # missing-import errors and (where written) falls back internally.
    exec python3 "$@"
fi

echo "Error: no python runtime available (need a .venv, uv, or python3)." >&2
echo "  Bootstrap: cd $REPO_ROOT && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt" >&2
exit 127
