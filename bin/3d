#!/usr/bin/env bash
# =============================================================================
# 3d — a scriptable CLI for AI-assisted, reference-photo-driven parametric 3D
#      modeling in OpenSCAD. Operationalizes the lego-loco research report:
#      camera-locked renders, silhouette scoring, forced-monotonic match loop,
#      manifold/printability/collision gates, and OpenSCAD library management.
#
# Subcommand dispatcher. Each command lives in lib/cmd_<name>.sh (bash) or is a
# thin wrapper around a python tool in lib/ run through lib/pyrun.
# =============================================================================
set -uo pipefail

# ---- resolve REPO_ROOT through the bin/3d symlink (macOS has no readlink -f) --
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
REPO_ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
export REPO_ROOT
LIB="$REPO_ROOT/lib"

VERSION="0.1.0"

# Shared helpers (also auto-exports OPENSCADPATH from libs/) + first-run bootstrap.
source "$LIB/common.sh"
maybe_bootstrap

# ---- color (only when stdout is a tty) --------------------------------------
if [ -t 1 ]; then B=$'\e[1m'; C=$'\e[36m'; Y=$'\e[33m'; R=$'\e[31m'; Z=$'\e[0m'
else B=""; C=""; Y=""; R=""; Z=""; fi

usage() {
cat <<EOF
${B}3d${Z} — scriptable 3D / OpenSCAD pipeline CLI  (v$VERSION)

${B}USAGE${Z}
  3d <command> [args]
  3d <command> --help        per-command help
  3d help                    this text
  3d version                 print version

${B}RENDER & VIEW${Z}
  ${C}render${Z}   <file.scad> [-o out.png] [--cam ex,ey,ez,cx,cy,cz] [--size WxH] [--ortho] [-D k=v]...
                  CGAL (--render) PNG with a locked 6-param vector camera. Default: ISO.
  ${C}preview${Z}  <file.scad> [-o out.png] [--cam ...] [--size WxH] [-D k=v]...
                  Fast throwntogether preview (no CGAL).
  ${C}multi${Z}    <file.scad> <outdir> [--render] [-D k=v]...
                  6-angle previews: iso/front/back/left/right/top.
  ${C}section${Z}  <file.scad> -o out.png [--plane YZ|XZ|XY] [--module 'name();'] [--keep neg|pos] [--size WxH]
                  Colored cross-section (6-param vector camera; never 7-param gimbal).

${B}GEOMETRY & EXPORT${Z}
  ${C}export${Z}   <file.scad> [-o out.stl|.3mf] [-D k=v]... [--ascii]
                  STL/3MF export WITH manifold/self-intersect validation. Nonzero exit on bad geometry.
  ${C}validate${Z} <file.scad>
                  Fast syntax check (no render).
  ${C}params${Z}   <file.scad> [--json]
                  Extract customizable parameters (Customizer-style comments).

${B}QA & GATES${Z}
  ${C}check${Z}        <file.scad>           manifold (--render + grep ERROR/WARNING) + quick printability. PASS/FAIL.
  ${C}mesh${Z}         <file.stl|.scad>      watertight/manifold/self-intersect/volume (trimesh/manifold3d/open3d; fallback: openscad warnings).
  ${C}printability${Z} <file.scad>           wall / min-feature / overhang / orientation flags (FDM, PLA/PETG).
  ${C}acceptance${Z}   <assembly.scad> [--ref img] [--collision cfg.json]
                                          master gate: manifold + consistency + printability (+ collision/silhouette if configured).
  ${C}collision${Z}    <config.json>         generic collision/penetration engine (static).

${B}REFERENCE-MATCH PIPELINE${Z}
  ${C}silhouette${Z} <file.scad> [-o mask.png] [--cam ...] [--size WxH]   camera-locked render -> binary silhouette mask.
  ${C}overlay${Z}    <render.png> <reference.png> [-o outdir]            difference / ghost / canny edge-overlay diagnostics.
  ${C}score${Z}      <render.png|file.scad> <reference> [-o outdir]      silhouette AE + IoU (machine-parseable lines).
  ${C}match${Z}      <assembly.scad> <reference> [--rounds N] [--dry-run] [--constants f] [--metric iou|ae]
                                          forced-monotonic acceptance loop (render->score->critic->apply->accept/revert + changelog).
  ${C}fit-camera${Z} <model.scad> <reference> [--out camera.json] [--rand N] [--refine N] [--draw-axes]
                                          fit an OpenSCAD camera to a reference photo by maximizing silhouette IoU; saves the viewpoint.
  ${C}preprocess${Z} <reference.jpg> [-o outdir]                        subject mask + proportional depth (SAM2/Depth-Anything if installable, else OpenCV).

${B}SLICING${Z}
  ${C}slice${Z}    <stl|3mf|file.scad> [-o out.gcode] [--printer NAME] [--profile FILE] [--check]
                  Slice to G-code via OrcaSlicer / Bambu Studio / PrusaSlicer (auto-detected).
                  --check = sliceability gate (nonzero exit on failure). .scad is exported first.

${B}LIBRARIES${Z}
  ${C}libs install${Z} bosl2|nopscadlib|all     clone OpenSCAD libraries into libs/.
  ${C}libs path${Z}                             print the OPENSCADPATH to export.
  ${C}libs list${Z}                             show installed libraries.

${B}ENVIRONMENT${Z}
  ${C}doctor${Z}                                detect present/missing deps (openscad, magick, python, uv,
                                          mesh stack, slicer) with the exact install command per OS.
  ${C}setup${Z}    [--yes] [--dry-run] [--no-slicer]
                  install the missing deps, OS-aware (brew / apt / dnf / pacman + repo .venv).

Run '3d <command> --help' for details and examples.
EOF
}

cmd="${1:-help}"
[ $# -gt 0 ] && shift

case "$cmd" in
    help|-h|--help)        usage ;;
    version|-v|--version)  echo "3d v$VERSION" ;;

    render|preview|multi|section|export|validate|params|check|printability|acceptance|silhouette|overlay|score)
        bash "$LIB/cmd_${cmd}.sh" "$@" ;;

    mesh|collision|match|preprocess|libs|fit-camera|slice|doctor|setup)
        bash "$LIB/cmd_${cmd}.sh" "$@" ;;

    *)
        echo "${R}3d: unknown command '$cmd'${Z}" >&2
        echo "Run '3d help' for the list of commands. Closest matches:" >&2
        compgen -W "render preview multi section export validate params check mesh printability acceptance collision silhouette overlay score match fit-camera preprocess libs slice doctor setup help version" \
            | grep -i "$(printf '%s' "$cmd" | cut -c1-3)" 2>/dev/null | sed 's/^/  /' >&2 || true
        exit 2 ;;
esac
